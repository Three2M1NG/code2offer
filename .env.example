# === LLM ===
# DeepSeek V4 Pro (主力，直连)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro

# === 阿里云百炼 ===
BAILIAN_API_KEY=aliyun_sk-your-bailian-key

# 百炼 — GLM-5.1（备用 LLM，OpenAI 兼容端口）
BAILIAN_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
BAILIAN_LLM_MODEL=glm-5.1

# 百炼 — qwen3-asr-flash（语音识别）
# BAILIAN_ASR_BASE_URL 可选，留空则自动使用 DashScope 官方端点
BAILIAN_ASR_MODEL=qwen3-asr-flash

# SenseVoice 本地模型（后续集成）
SENSEVOICE_MODEL_PATH=

# === Database ===
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/code2offer

# === Monitoring ===
SENTRY_DSN=
